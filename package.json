{
  "name": "eu-match",
  "version": "0.9.0",
  "description": "AI-powered Electron app for EU funding scouting using Copilot CLI",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.renderer.json",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "keywords": [
    "electron",
    "EU",
    "funding",
    "startup",
    "copilot"
  ],
  "author": "EU-Match",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "electron-store": "^8.2.0",
    "marked": "^17.0.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.eu-match.app",
    "productName": "EU-Match",
    "artifactName": "eu-match-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/icon.icns",
      "target": "dmg"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": {
        "target": "nsis",
        "arch": ["x64"]
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "shortcutName": "EU-Match"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Office",
      "target": {
        "target": "AppImage",
        "arch": ["x64"]
      },
      "synopsis": "AI-powered EU funding scout",
      "description": "Discover and rank EU funding opportunities for your startup using Copilot AI deep analysis."
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "!renderer/**/*.ts",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}
