{
  "name": "startup-eu-scout",
  "version": "0.1.0",
  "description": "AI-powered Electron app for startups to automate EU funding discovery and partnership matching. Integrates the EU Tenders Portal with Copilot CLI (Opus 4.6).",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && electron .",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "keywords": [
    "electron",
    "eu-funding",
    "startup",
    "copilot",
    "ai"
  ],
  "author": "Luca Nardelli",
  "license": "MIT",
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.30",
    "electron": "^33.4.2",
    "eslint": "^9.23.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.1",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "cheerio": "^1.0.0",
    "electron-store": "^8.2.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "moduleNameMapper": {
      "^electron$": "<rootDir>/tests/__mocks__/electron.ts"
    }
  }
}
